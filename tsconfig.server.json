{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "./dist/server",
    "rootDir": "./src/server",
    "declaration": false
  },
  "include": ["src/server/**/*"],
  "exclude": ["node_modules", "dist"]
}
